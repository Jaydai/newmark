# =============================================================================
# Jaydai Newmark — VM Deployment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Then run: ./scripts/build-apps.sh && docker compose up -d
# =============================================================================

# ── Domain ──
DOMAIN=nmrk-jayd.ai

# ── Azure AD / Tenant ──
AZURE_TENANT_ID=
AZURE_CLIENT_ID=

# ── AI Services ──
AZURE_AI_ENDPOINT=
AZURE_AI_KEY=
AI_MODEL=gpt-4o-mini

# ── API Key (protects agent endpoints from unauthorized access) ──
API_KEY=change-me-to-a-random-string

# ── Scraper Credentials ──
BUSINESS_IMO_EMAIL=
BUSINESS_IMO_PASSWORD=
LEMONDE_EMAIL=
LEMONDE_PASSWORD=
LAPLACE_EMAIL=
LAPLACE_PASSWORD=

# ── Power Automate ──
POWER_AUTOMATE_WEBHOOK=

# ── Let's Encrypt ──
LETSENCRYPT_EMAIL=
